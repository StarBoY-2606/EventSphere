# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
build/
backend/dist/
frontend/dist/

# ── Environment variables (NEVER commit these) ────────────────────────────────
.env
.env.local
.env.production
backend/.env
backend/.env.local
backend/.env.production
!backend/.env.example

# ── Database files (auto-generated) ──────────────────────────────────────────
backend/data.json
backend/activities.json

# ── Uploads (user generated content) ─────────────────────────────────────────
backend/public/uploads/
uploads/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ── OS files ──────────────────────────────────────────────────────────────────
